#!/bin/bash

# run_once_after_setup-gnome.sh.tmpl
# This script runs exactly once per machine during the first 'chezmoi apply'.

if [ -n "$DISPLAY" ]; then
    echo "🚀 Performing first-time GNOME configuration..."
    
    # Path to your exported settings
    SETTING_FILE="{{ .chezmoi.homeDir }}/.config/dconf/settings.ini"

    if [ -f "$SETTING_FILE" ]; then
        dconf load /org/gnome/ < "$SETTING_FILE"
        echo "✅ GNOME settings applied successfully."
    else
        echo "⚠️  Configuration file not found at $SETTING_FILE"
    fi
fi
