# .bashrc

# 1. Source global definitions (DO THIS FIRST)
if [ -f /etc/bashrc ]; then
    . /etc/bashrc
fi

# 2. User specific environment (PATH)
# This ensures Bash knows where your tools are before handing off to Fish
if ! [[ "$PATH" =~ "$HOME/.local/bin" ]]; then
    export PATH="$HOME/.local/bin:$HOME/bin:$PATH"
fi

